    {
      "parameters": {
        "jsCode": "// CHUNK: start 3 to test. 0 = all. Use ~50 for safe chunks on the full run.\n// Skip: invalid, already has phone, already requested (phone_reveal_requested), no email/linkedin.\nconst CHUNK = 50;\nconst docs = ($json.documents) || [];\nconst out = [];\nfor (const d of docs) {\n  const f = d.fields || {};\n  const S = k => (f[k] && f[k].stringValue != null) ? f[k].stringValue : '';\n  const B = k => !!(f[k] && f[k].booleanValue);\n  const slug = (d.name || '').split('/').pop();\n  if (!slug) continue;\n  if (f.invalid && f.invalid.booleanValue) continue;\n  if (S('phone')) continue;\n  if (B('phone_reveal_requested')) continue;\n  const email = S('email'); const linkedin = S('linkedin');\n  if (!email && !linkedin) continue;\n  out.push({ json: { slug, email, linkedin, name: S('first_name'), domain: S('domain') } });\n}\nreturn CHUNK ? out.slice(0, CHUNK) : out;"
      },
      "id": "ea8c04d5-8158-4502-a15b-35b3644ff891",
      "name": "Parse targets",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1712,
        2448
      ]
    },
    {
      "parameters": {
        "jsCode": "// Run for ALL items: build one reveal body per target (was collapsing to 1).\nconst out = [];\nfor (const it of $input.all()) {\n  const t = it.json;\n  let detail;\n  if (t.email) detail = { email: t.email };\n  else if (t.linkedin) detail = { linkedin_url: t.linkedin };\n  else { const p = String(t.name || '').trim().split(/\\s+/); detail = { first_name: p[0] || '', last_name: p.slice(1).join(' ') || '', domain: t.domain }; }\n  out.push({ json: { slug: t.slug, reqBody: { details: [ detail ] } } });\n}\nreturn out;"
      },
      "id": "0f5cc95f-eed3-4314-a89d-d5d0ac29f82f",
      "name": "Build reveal body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1504,
        2448
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.apollo.io/api/v1/people/bulk_match",
