rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────
// Do-or-Wait Firestore security rules
//
// LIVE / PUBLISHED (locked down 2026-06-24). Two roles:
//   1. Full users (isAllowed)   — everything, read + write. MUST match
//      ALLOWED_EMAILS in index.html.
//   2. Avail-only (isAvailOnly) — READ-ONLY on availability/config/renewals
//      and roster data (what the Avail + Roster tabs show — Roster was
//      opened up to this role 2026-07-07, unlike Pricing/Rate Bands, since
//      it's just a staff contact directory, not sensitive/negotiating data).
//      No access to anything else (leads, tasks, notes, outreach, pricing,
//      pricing_bd), even via a direct Firestore call from the browser
//      console. MUST match
//      AVAIL_ONLY_EMAILS in index.html. This is the real enforcement for
//      that restricted role — index.html only controls what the UI shows;
//      this is what actually stops her token from reading/writing more.
//
// n8n is unaffected either way — its Google service account bypasses
// rules entirely (IAM, not these rules).
// ─────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // Full access. Emails lowercased to compare. (No email_verified check —
    // the email/password accounts are hand-created in the console and
    // aren't "verified"; the allowlist is the real gate.)
    function isAllowed() {
      return request.auth != null
        && request.auth.token.email.lower() in [
          'jchoustin91@gmail.com',
          'justin.cho@cubework.com',
          'cubeworkautomation@gmail.com'
        ];
    }

    // Restricted role: read-only, Avail-tab data only.
    function isAvailOnly() {
      return request.auth != null
        && request.auth.token.email.lower() in [
          'lucy.wang@cubework.com'
        ];
    }

    function isAnyAllowed() {
      return isAllowed() || isAvailOnly();
    }

    // Avail-tab data: full users read/write, avail-only users read-only.
    match /availability/{propId} {
      allow read:  if isAnyAllowed();
      allow write: if isAllowed();
    }
    match /config/properties {
      allow read:  if isAnyAllowed();
      allow write: if isAllowed();
    }
    match /renewals/current {
      allow read:  if isAnyAllowed();
      allow write: if isAllowed();
    }
    match /roster/current {
      allow read:  if isAnyAllowed();
      allow write: if isAllowed();
    }

    // Everything else (topics, leads, notes, outreach, pricing, pricing_bd,
    // apollo_phone_map, floorplans, etc.) — full users only.
    match /{document=**} {
      allow read, write: if isAllowed();
    }
  }
}
