    {
      "parameters": {
        "jsCode": "// Run for ALL items: one output per reveal (was collapsing 50 -> 1).\n// Apollo's person id (matches[0].id) is a normal hex string, no precision issue.\nconst reveals = $('Build reveal body').all();\nconst items = $input.all();\nconst out = [];\nfor (let i = 0; i < items.length; i++) {\n  const r = items[i].json || {};\n  const arr = r.matches || r.people || [];\n  const pid = (arr[0] && arr[0].id) ? String(arr[0].id) : '';\n  const slug = (reveals[i] && reveals[i].json && reveals[i].json.slug) || '';\n  const now = new Date().toISOString();\n  out.push({ json: { slug, personId: pid, ok: !!pid, mapBody: { fields: { slug: { stringValue: slug }, created_at: { timestampValue: now } } }, markBody: { fields: { phone_reveal_requested: { booleanValue: true } } } } });\n}\nreturn out;"
      },
